{
  "manifest_version": 3,
  "name": "Olis Riffel",
  "version": "1.3.0",
  "icons": {
    "16": "crosshair16x16.png",
    "48": "crosshair48x48.png",
    "128": "crosshair128x128.png"
  },
  "permissions": [
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "*://*.forgeofempires.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_title": "Snipe time",
    "default_icon": {
      "16": "crosshair16x16.png",
      "48": "crosshair48x48.png",
      "128": "crosshair128x128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/inject.js"
      ],
      "matches": [
        "*://*.forgeofempires.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "js": [
        "src/content.jsx"
      ],
      "matches": [
        "*://*.forgeofempires.com/*"
      ],
      "run_at": "document_start"
    }
  ]
}